model user {
  id            String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(120)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  cpf           String    @unique @db.Char(11)
  phone         String   @db.VarChar(20)
  cep           String?   @db.Char(8)
  city          String?   @db.VarChar(100)
  state         String?   @db.Char(2)
  avatar_url    String?   @db.Text
  bio           String?   @db.Text
  is_verified   Boolean   @default(false) @db.Boolean
  is_active     Boolean   @default(true) @db.Boolean
  refresh_token String?   @db.Text
  last_login_at DateTime? @db.Timestamptz()
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @db.Timestamptz()

  listing              listing[]
  favorites            favorites[]
  conversationAsBuyer  conversation[] @relation("BuyerConversation")
  conversationAsSeller conversation[] @relation("SellerConversation")
  sentMessages         message[]      @relation("SentMessage")
  seller_stats         seller_stats[]
  reviewsAsSeller      review[]       @relation("SellerReview")
  reviewsAsReviewer    review[]       @relation("ReviewerReview")
  reports              report[]
  listing_comments     listing_comment[]

  // Exemplo 1 — índice simples: acelera filtro por estado
  @@index([state], map: "idx_users_state")
  @@index([email], map: "idx_users_email")
  @@index([cpf], map: "idx_users_cpf")
  // Exemplo 2 — índice parcial: só indexa usuários ativos (WHERE is_active = TRUE)
  @@index([is_active], map: "idx_users_is_active", where: raw("is_active = TRUE"))
  @@map("users")
}

model listing {
  id               String            @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id        String            @db.Uuid
  seller           user              @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  title            String            @db.VarChar(200)
  description      String?           @db.Text
  category         listing_category
  condition        vehicle_condition
  status           listing_status    @default(ATIVO)
  brand            String            @db.VarChar(80)
  model            String            @db.VarChar(120)
  year_model       Int               @db.SmallInt
  year_manuf       Int?              @db.SmallInt
  color            String?           @db.VarChar(50)
  fuel             fuel_type
  transmission     transmission_type
  km               Int?
  doors            Int?              @db.SmallInt
  engine_cc        Int?
  license_plate    String?           @db.VarChar(10)
  fipe_code        String?           @db.VarChar(20)
  price            Decimal           @db.Decimal(12, 2)
  price_negotiable Boolean           @default(true) @db.Boolean
  accepts_trade    Boolean           @default(false) @db.Boolean
  city             String            @db.VarChar(100)
  state            String            @db.Char(2)
  cep              String?           @db.Char(8)
  views_count      Int               @default(0) @db.Integer
  featured         Boolean           @default(false) @db.Boolean
  featured_until   DateTime?         @db.Timestamptz()
  expires_at       DateTime          @default(dbgenerated("(NOW() + INTERVAL '90 days')")) @db.Timestamptz()
  published_at     DateTime?         @db.Timestamptz()
  created_at       DateTime          @default(now()) @db.Timestamptz()
  updated_at       DateTime          @default(now()) @db.Timestamptz()
  featured_amount  Decimal           @default(0)
  popular_name     String?           @db.VarChar(20)
  plate            String            @db.VarChar(7)
  bullet_proof     Boolean           @default(false)  
  auction          Boolean           @default(false)
  observation      String?           @db.VarChar() 
  security_components   security_components[]
  comfort_components    comfort_components[]
  technology_components technology_components[]
  mechanic_components   mechanic_components[]
  search_vector    Unsupported("tsvector")?

  listing_images   listing_image[]
  favorites        favorites[]
  conversation     conversation[]
  reviews          review[]
  reports          report[]
  listing_comments listing_comment[]

  // Exemplo 3 — índice com ordenação: listagem por mais recentes
  @@index([created_at(sort: Desc)], map: "idx_listings_created_at")
  @@index([seller_id], map: "idx_listings_seller_id")
  @@index([status], map: "idx_listings_status")
  @@index([category], map: "idx_listings_category")
  @@index([state], map: "idx_listings_state")
  @@index([price], map: "idx_listings_price")
  @@index([year_model], map: "idx_listings_year_model")
  @@index([brand], map: "idx_listings_brand")
  @@index([popular_name], map: "idx_listing_popular_name")
  @@index([plate], map: "idx_listing_plate")
  @@index([featured, featured_until], map: "idx_listings_featured", where: raw("featured = TRUE"))
  @@index([expires_at], map: "idx_listings_expires_at", where: raw("status = 'ATIVO'"))
  // Exemplo 4 — índice composto parcial: filtro principal de /anuncios
  @@index([state, category, status, price], map: "idx_listings_browse", where: raw("status = 'ATIVO'"))
  // search_vector (GIN) fica em prisma/migrations/gin_indexes.sql
  @@map("listings")
}

model listing_image {
  id         String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id String   @db.Uuid
  listing    listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  url        String   @db.Text
  position   Int      @db.SmallInt
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([listing_id, position], map: "idx_listing_images_listing_id")

  @@map("listing_images")
}

model favorites {
  user_id    String   @db.Uuid
  user       user    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing_id String   @db.Uuid
  listing    listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([user_id], map: "idx_favorites_user_id")
  @@index([listing_id], map: "idx_favorites_listing_id")

  @@id([user_id, listing_id])
  @@map("favorites")
}

model conversation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id  String    @db.Uuid
  listing     listing   @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  buyer_id    String    @db.Uuid
  buyer       user      @relation("BuyerConversation", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller_id   String    @db.Uuid
  seller      user      @relation("SellerConversation", fields: [seller_id], references: [id], onDelete: Cascade)
  is_archived Boolean   @default(false) @db.Boolean
  created_at  DateTime  @default(now()) @db.Timestamptz()
  updated_at  DateTime  @default(now()) @db.Timestamptz()
  messages    message[]

  @@index([buyer_id], map: "idx_conversations_buyer_id")
  @@index([seller_id], map: "idx_conversations_seller_id")
  @@index([listing_id], map: "idx_conversations_listing")

  @@map("conversations")
}

model message {
  id              String         @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String         @db.Uuid
  conversation    conversation   @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender_id       String         @db.Uuid
  sender          user           @relation("SentMessage", fields: [sender_id], references: [id], onDelete: Cascade)
  body            String         @db.Text
  status          message_status @default(ENVIADA)
  created_at      DateTime       @default(now()) @db.Timestamptz()

  @@index([conversation_id, created_at(sort: Desc)], map: "idx_messages_conversation_id")
  @@index([sender_id], map: "idx_messages_sender_id")
  @@index([status], map: "idx_messages_status", where: raw("status = 'ENVIADA'"))


  @@map("messages")
}

model seller_stats {
  user_id         String   @db.Uuid
  user            user    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  total_listings  Int      @default(0) @db.Integer
  active_listings Int      @default(0) @db.Integer
  sold_count      Int      @default(0) @db.Integer
  avg_rating      Decimal? @db.Decimal(3, 2)
  review_count    Int      @default(0) @db.Integer
  updated_at      DateTime @default(now()) @db.Timestamptz()

  @@id([user_id])
  @@map("seller_stats")
}

model review {
  id          String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id   String   @db.Uuid
  seller      user     @relation("SellerReview", fields: [seller_id], references: [id], onDelete: Cascade)
  reviewer_id String   @db.Uuid
  reviewer    user    @relation("ReviewerReview", fields: [reviewer_id], references: [id], onDelete: Cascade)
  listing_id  String?  @db.Uuid
  listing     listing? @relation(fields: [listing_id], references: [id], onDelete: SetNull)
  rating      Int      @db.SmallInt
  comment     String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([seller_id], map: "idx_reviews_seller_id")
  @@index([reviewer_id], map: "idx_reviews_reviewer_id")

  @@unique([listing_id, reviewer_id])
  @@map("reviews")
}

model report {
  id          String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id  String        @db.Uuid
  listing     listing       @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  reporter_id String        @db.Uuid
  reporter    user          @relation(fields: [reporter_id], references: [id], onDelete: Cascade)
  reason      report_reason
  details     String?       @db.Text
  status      report_status @default(PENDENTE)
  resolved_at DateTime?     @db.Timestamptz()
  created_at  DateTime      @default(now()) @db.Timestamptz()

  @@index([listing_id], map: "idx_reports_listing_id")
  @@index([status], map: "idx_reports_status", where: raw("status = 'PENDENTE'"))

  @@unique([listing_id, reporter_id])
  @@map("reports")
}

model listing_comment {
  id         String           @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id String           @db.Uuid
  listing    listing          @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  author_id  String           @db.Uuid
  author     user             @relation(fields: [author_id], references: [id], onDelete: Cascade)
  body       String           @db.Text
  parent_id  String?          @db.Uuid
  parent     listing_comment? @relation("CommentReplies", fields: [parent_id], references: [id])
  replies    listing_comment[] @relation("CommentReplies")
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now()) @db.Timestamptz()

  @@index([listing_id], map: "idx_listing_comments_listing_id")
  @@map("listing_comments")
}
